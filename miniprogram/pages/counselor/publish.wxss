/* pages/counselor/publish.wxss - 与首页统一的配色方案 */
page { background: #f5fff9; }

.publish-container { padding: 30rpx; padding-bottom: 120rpx; }

.form-section { margin-bottom: 40rpx; }

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.cover-upload {
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f5f5f5;
}
.cover-upload image { width: 100%; height: 100%; }

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}
.upload-icon { font-size: 60rpx; margin-bottom: 16rpx; }
.upload-text { font-size: 26rpx; color: #999; }

picker .picker-value {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
}

.content-section { flex: 1; }

.form-textarea {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  width: 100%;
  min-height: 500rpx;
  box-sizing: border-box;
  line-height: 1.8;
}

.submit-btn {
  background: linear-gradient(135deg, #8ddaf8 0%, #B4E8D1 100%);
  color: #fff;
  font-size: 32rpx;
  padding: 28rpx;
  border-radius: 50rpx;
  margin-top: 40rpx;
  border: none;
  position: fixed;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
}
