<!--pages/login/login.wxml-->
<view class="login-container">
  <!-- 顶部背景 -->
  <view class="header-bg">
    <view class="logo-area">
      <view class="logo-icon">💜</view>
      <text class="app-name">心晴</text>
      <text class="app-subtitle">大学生心理健康助手</text>
    </view>
  </view>

  <!-- 功能介绍 -->
  <view class="features">
    <view class="feature-item">
      <view class="feature-icon" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
        <text class="icon-emoji">📖</text>
      </view>
      <text class="feature-text">心理文章</text>
    </view>
    <view class="feature-item">
      <view class="feature-icon" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
        <text class="icon-emoji">📝</text>
      </view>
      <text class="feature-text">心理测评</text>
    </view>
    <view class="feature-item">
      <view class="feature-icon" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
        <text class="icon-emoji">🌳</text>
      </view>
      <text class="feature-text">心理树洞</text>
    </view>
    <view class="feature-item">
      <view class="feature-icon" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);">
        <text class="icon-emoji">🤖</text>
      </view>
      <text class="feature-text">AI分析</text>
    </view>
  </view>

  <!-- 角色选择 -->
  <view class="role-section">
    <text class="role-title">请选择您的身份</text>
    <view class="role-list">
      <view 
        class="role-item {{selectedRole === 'user' ? 'selected' : ''}}"
        data-role="user"
        bindtap="selectRole"
      >
        <view class="role-icon">👤</view>
        <view class="role-info">
          <text class="role-name">学生</text>
          <text class="role-desc">浏览文章、参与测评、倾诉心事</text>
        </view>
        <view class="role-check" wx:if="{{selectedRole === 'user'}}">✓</view>
      </view>
      
      <view 
        class="role-item {{selectedRole === 'counselor' ? 'selected' : ''}}"
        data-role="counselor"
        bindtap="selectRole"
      >
        <view class="role-icon">👨‍⚕️</view>
        <view class="role-info">
          <text class="role-name">心理咨询师</text>
          <text class="role-desc">回复咨询、发布文章、管理预约</text>
        </view>
        <view class="role-check" wx:if="{{selectedRole === 'counselor'}}">✓</view>
      </view>
      
      <view 
        class="role-item {{selectedRole === 'admin' ? 'selected' : ''}}"
        data-role="admin"
        bindtap="selectRole"
      >
        <view class="role-icon admin-icon">🔐</view>
        <view class="role-info">
          <text class="role-name">管理员</text>
          <text class="role-desc">系统管理、数据统计</text>
        </view>
        <view class="role-check" wx:if="{{selectedRole === 'admin'}}">✓</view>
      </view>
    </view>
  </view>

  <!-- 学生登录 - 微信一键登录 -->
  <view class="login-section" wx:if="{{selectedRole === 'user'}}">
    <button 
      class="login-btn wechat-btn" 
      type="primary" 
      bindtap="getUserProfile"
    >
      微信授权登录
    </button>
    <text class="login-tip">登录即表示同意我们的服务条款和隐私政策</text>
  </view>

  <!-- 咨询师登录 - 双模式 -->
  <view class="login-section" wx:if="{{selectedRole === 'counselor'}}">
    <!-- 微信登录 -->
    <button 
      class="login-btn wechat-btn" 
      type="primary" 
      bindtap="getUserProfile"
    >
      微信授权登录
    </button>
    
    <view class="divider">
      <view class="divider-line"></view>
      <text class="divider-text">或</text>
      <view class="divider-line"></view>
    </view>
    
    <!-- 账号密码登录 -->
    <button 
      class="login-btn account-btn" 
      bindtap="showAccountLogin"
    >
      账号密码登录
    </button>
  </view>

  <!-- 管理员登录 - 纯账号密码 -->
  <view class="login-section" wx:if="{{selectedRole === 'admin'}}">
    <view class="account-form">
      <input 
        class="form-input" 
        type="text" 
        placeholder="请输入管理员账号"
        bindinput="onUsernameInput"
        value="{{username}}"
      />
      <input 
        class="form-input" 
        type="password" 
        placeholder="请输入密码"
        bindinput="onPasswordInput"
        value="{{password}}"
      />
      <button 
        class="login-btn account-btn" 
        bindtap="handleAccountLogin"
      >
        登录
      </button>
    </view>
  </view>

  <!-- 账号密码登录弹窗 -->
  <view class="modal" wx:if="{{showAccountModal}}" bindtap="hideAccountLogin">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">账号密码登录</text>
        <text class="modal-close" bindtap="hideAccountLogin">✕</text>
      </view>
      <view class="modal-body">
        <input 
          class="form-input" 
          type="text" 
          placeholder="请输入账号/手机号"
          bindinput="onUsernameInput"
          value="{{username}}"
        />
        <input 
          class="form-input" 
          type="password" 
          placeholder="请输入密码"
          bindinput="onPasswordInput"
          value="{{password}}"
        />
        <view class="form-actions">
          <text class="register-link" bindtap="goToRegister">还没有账号？去注册</text>
        </view>
        <button 
          class="login-btn account-btn" 
          bindtap="handleAccountLogin"
        >
          登录
        </button>
      </view>
    </view>
  </view>

  <!-- 注册弹窗 -->
  <view class="modal" wx:if="{{showRegisterModal}}" bindtap="hideRegister">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">注册账号</text>
        <text class="modal-close" bindtap="hideRegister">✕</text>
      </view>
      <view class="modal-body">
        <input 
          class="form-input" 
          type="text" 
          placeholder="请输入账号/手机号"
          bindinput="onRegUsernameInput"
          value="{{regUsername}}"
        />
        <input 
          class="form-input" 
          type="password" 
          placeholder="请输入密码（至少6位）"
          bindinput="onRegPasswordInput"
          value="{{regPassword}}"
        />
        <input 
          class="form-input" 
          type="password" 
          placeholder="请确认密码"
          bindinput="onRegConfirmInput"
          value="{{regConfirm}}"
        />
        <button 
          class="login-btn account-btn" 
          bindtap="handleRegister"
        >
          注册
        </button>
      </view>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text class="footer-text">关注心理健康，守护美好心灵</text>
  </view>
</view>
