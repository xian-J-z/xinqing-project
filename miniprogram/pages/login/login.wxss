/* pages/login/login.wxss - 与首页统一的配色方案 */
page {
  background: #e8f5f9;
}

.login-container {
  width: 100%; 
  min-height: 100vh;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0;
}

.bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  opacity: 0.6;
}

.header-bg {
  width: 100%;
  padding: 250rpx 0 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.2);
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 80rpx;
}

.app-name {
  font-size: 56rpx;
  font-weight: 700;
  color: #30373b;
  margin-bottom: 12rpx;
}

.app-subtitle {
  font-size: 28rpx;
  color: rgba(19, 24, 24, 0.9);
}

.features {
  display: flex;
  justify-content: space-around;
  width: 90%;
  background: rgba(212, 207, 207, 0.15);
  border-radius: 30rpx;
  padding: 40rpx 20rpx;
  margin: 40rpx 0;
}

/* 角色选择 */
.role-section {
  width: 85%;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 50rpx;
  padding: 8rpx;
  margin: 20rpx 0;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(10rpx);
  position: relative;
  z-index: 100;
}

.role-picker-wrap {
  width: 100%;
  position: relative;
}

.role-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 36rpx;
  background: linear-gradient(135deg, rgba(141, 218, 248, 0.15) 0%, rgba(180, 232, 209, 0.15) 100%);
  border-radius: 42rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.6);
}

.picker-label {
  display: flex;
  flex-direction: column;
}

.picker-title {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.picker-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.picker-value.placeholder {
  color: #aaa;
  font-weight: normal;
}

.picker-arrow {
  font-size: 24rpx;
  color: #888;
  transition: transform 0.3s ease;
}

.arrow-up {
  transform: rotate(180deg);
}

/* 下拉菜单 */
.role-dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background: rgba(238, 243, 248, 0.85);
  border-radius: 30rpx;
  margin-top: 12rpx;
  overflow: hidden;
  opacity: 0;
  transform: translateY(-20rpx);
  transition: all 0.3s ease;
  pointer-events: none;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.15);
  z-index: 9999;
}

.dropdown-show {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.dropdown-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 36rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background 0.2s ease;
}

.dropdown-item:last-child {
  border-bottom: none;
}

.dropdown-item:active {
  background: linear-gradient(135deg, rgba(141, 218, 248, 0.15) 0%, rgba(180, 232, 209, 0.15) 100%);
}

.item-text {
  font-size: 30rpx;
  color: #333;
}

.item-selected .item-text {
  color: #7EC8E3;
  font-weight: 600;
}

.item-check {
  font-size: 28rpx;
  color: #7EC8E3;
  font-weight: bold;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feature-icon {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 12rpx;
  border-radius: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.15);
}

.icon-emoji {
  font-size: 48rpx;
}

.feature-text {
  font-size: 28rpx;
  color: #333;
}

.login-section {
  width: 85%;
  margin-top: 60rpx;
}

.login-btn {
  width: 100%;
  background: #fff;
  color: #5B9BD5;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 50rpx;
  padding: 30rpx 0;
  box-shadow: 0 12rpx 40rpx rgba(141, 218, 248, 0.4);
  transition: all 0.3s ease;
}

.login-btn::after {
  border: none;
}

.wechat-btn {
  background: linear-gradient(135deg, #7EC8E3 0%, #A8E6CF 100%);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.wechat-btn:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 20rpx rgba(141, 218, 248, 0.3);
}

.account-btn {
  background: linear-gradient(135deg, #7EC8E3 0%, #A8E6CF 100%);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.account-btn:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 20rpx rgba(141, 218, 248, 0.3);
}

.login-tip {
  display: block;
  text-align: center;
  font-size: 23rpx;
  color: rgba(6, 6, 6, 0.8);
  margin-top: 40rpx;
}

/* 分隔符 */
.divider {
  display: flex;
  align-items: center;
  margin: 30rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.5);
}

.divider-text {
  padding: 0 20rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

/* 账号表单 */
.account-form {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
}

.form-input {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #e8e8e8;
}

.form-input:focus {
  border-color: #8ddaf8;
}

.form-actions {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 20rpx;
}

.register-link {
  color: #5B9BD5;
  font-size: 26rpx;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  width: 85%;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.modal-body {
  padding: 30rpx;
}

.modal-body .form-input {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #e8e8e8;
}

.modal-body .login-btn {
  margin-top: 10rpx;
}

.footer {
  margin-top: auto;
  padding: 60rpx 0 80rpx;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.7);
}
