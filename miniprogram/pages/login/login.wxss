/* pages/login/login.wxss - 与首页统一的配色方案 */
page {
  background: #f5fff9;
}

.login-container {
  min-height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0;
}

.header-bg {
  width: 100%;
  padding: 100rpx 0 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.2);
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 80rpx;
}

.app-name {
  font-size: 56rpx;
  font-weight: 700;
  color: #30373b;
  margin-bottom: 12rpx;
}

.app-subtitle {
  font-size: 28rpx;
  color: rgba(19, 24, 24, 0.9);
}

.features {
  display: flex;
  justify-content: space-around;
  width: 90%;
  background: rgba(212, 207, 207, 0.15);
  border-radius: 30rpx;
  padding: 40rpx 20rpx;
  margin: 40rpx 0;
}

/* 角色选择 */
.role-section {
  width: 85%;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 20rpx 0;
}

.role-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 24rpx;
}

.role-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.role-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 4rpx solid transparent;
  transition: all 0.3s ease;
}

.role-item.selected {
  background: #e8f5f9;
  border-color: #8ddaf8;
}

.role-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8ddaf8 0%, #B4E8D1 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.role-icon.admin-icon {
  background: linear-gradient(135deg, #8ddaf8 0%, #B4E8D1 100%);
}

.role-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.role-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.role-desc {
  font-size: 22rpx;
  color: #888;
}

.role-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8ddaf8 0%, #B4E8D1 100%);
  color: #fff;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
  font-weight: bold;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feature-icon {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 12rpx;
  border-radius: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.15);
}

.icon-emoji {
  font-size: 48rpx;
}

.feature-text {
  font-size: 28rpx;
  color: #333;
}

.login-section {
  width: 85%;
  margin-top: 60rpx;
}

.login-btn {
  width: 100%;
  background: #fff;
  color: #5B9BD5;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 50rpx;
  padding: 26rpx 0;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
}

.login-btn::after {
  border: none;
}

.wechat-btn {
  background: linear-gradient(135deg, #8ddaf8 0%, #B4E8D1 100%);
  color: #fff;
}

.account-btn {
  background: linear-gradient(135deg, #8ddaf8 0%, #B4E8D1 100%);
  color: #fff;
}

.login-tip {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 30rpx;
}

/* 分隔符 */
.divider {
  display: flex;
  align-items: center;
  margin: 30rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.5);
}

.divider-text {
  padding: 0 20rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

/* 账号表单 */
.account-form {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
}

.form-input {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #e8e8e8;
}

.form-input:focus {
  border-color: #8ddaf8;
}

.form-actions {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 20rpx;
}

.register-link {
  color: #5B9BD5;
  font-size: 26rpx;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  width: 85%;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.modal-body {
  padding: 30rpx;
}

.modal-body .form-input {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #e8e8e8;
}

.modal-body .login-btn {
  margin-top: 10rpx;
}

.footer {
  margin-top: auto;
  padding: 60rpx 0 80rpx;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}
