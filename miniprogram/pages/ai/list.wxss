/* pages/ai/list.wxss - 与首页统一的配色方案 */
page {
  background: #f5fff9;
}

.list-container {
  min-height: 100vh;
  background: #f5fff9;
  padding: 30rpx;
}

.record-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.emotion-section {
  display: flex;
  align-items: center;
}

.emotion-icon {
  font-size: 48rpx;
  margin-right: 12rpx;
}

.emotion-label {
  font-size: 32rpx;
  font-weight: 600;
}

.record-badge {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.badge-good {
  background: rgba(67, 233, 123, 0.1);
  color: #43e97b;
}

.badge-normal {
  background: rgba(141, 218, 248, 0.15);
  color: #5B9BD5;
}

.badge-warn {
  background: rgba(255, 184, 77, 0.1);
  color: #ffb84d;
}

.badge-bad {
  background: rgba(255, 107, 107, 0.1);
  color: #ff6b6b;
}

.input-section {
  margin-bottom: 20rpx;
}

.section-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.input-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  background: #f5f5f5;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  display: block;
}

.keywords-section {
  margin-bottom: 20rpx;
}

.keywords-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.keyword-tag {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #8ddaf8 0%, #B4E8D1 100%);
  color: #fff;
  border-radius: 20rpx;
}

.suggestions-section {
  margin-bottom: 20rpx;
}

.suggestion-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: block;
  margin-bottom: 6rpx;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.record-date {
  font-size: 24rpx;
  color: #ccc;
}

.action-btns {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  font-size: 24rpx;
  color: #5B9BD5;
}

.action-btn.delete {
  color: #ff6b6b;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  color: #ccc;
  font-size: 28rpx;
}

.empty-hint {
  font-size: 24rpx;
  margin-top: 16rpx;
  color: #999;
}
