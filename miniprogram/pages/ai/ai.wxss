/* AI心理分析页面 - 淡粉色主题 */
.ai-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #fefefe;
  position: relative;
}

/* 头部 */
.ai-header {
  background: #fce7f3;
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}

.ai-header-left {
  display: flex;
  align-items: center;
}

.ai-avatar {
  width: 70rpx;
  height: 70rpx;
  background: rgba(255,255,255,0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 16rpx;
}

.ai-title-wrap {
  display: flex;
  flex-direction: column;
}

.ai-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #721c24;
}

.ai-subtitle {
  font-size: 20rpx;
  color: #856404;
}

.ai-restart {
  background: rgba(255,255,255,0.6);
  color: #721c24;
  border-radius: 24rpx;
  font-size: 22rpx;
  padding: 10rpx 20rpx;
  border: 1rpx solid #f5c6cb;
}

/* 聊天区域 */
.chat-area {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
  background: #fefefe;
}

.chat-list {
  padding-bottom: 20rpx;
}

.chat-item {
  display: flex;
  margin-bottom: 24rpx;
  align-items: flex-start;
}

.chat-item.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.ai-avatar-icon {
  background: #fce7f3;
  color: #666;
}

.user-avatar-icon {
  background: #e9ecef;
  color: #6c757d;
}

.bubble-wrap {
  max-width: 72%;
  margin: 0 12rpx;
}

.bubble {
  padding: 20rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.bubble.assistant {
  background: #fff;
  border: 1rpx solid #f5c6cb;
  border-bottom-left-radius: 6rpx;
}

.bubble.user {
  background: #f8d7da;
  color: #721c24;
  border-bottom-right-radius: 6rpx;
}

.bubble-text {
  word-break: break-all;
  white-space: pre-wrap;
}

.chat-time {
  font-size: 18rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}

.chat-item.user .chat-time {
  text-align: right;
}

/* 加载动画 */
.typing {
  display: flex;
  flex-direction: row;
  padding: 24rpx 32rpx;
}

.typing-dot {
  width: 10rpx;
  height: 10rpx;
  background: #f5c6cb;
  border-radius: 50%;
  margin: 0 4rpx;
  animation: typing-bounce 1.4s infinite ease-in-out;
}

.typing-dot:nth-child(1) { animation-delay: -0.32s; }
.typing-dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes typing-bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

/* 输入区域 */
.input-area {
  background: #fff;
  padding: 12rpx 20rpx;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f5c6cb;
  flex-shrink: 0;
}

.action-btns {
  margin-bottom: 12rpx;
}

.end-btn {
  width: 100%;
  background: #fff;
  color: #721c24;
  border-radius: 24rpx;
  font-size: 26rpx;
  padding: 16rpx;
  border: 1rpx solid #f5c6cb;
}

.input-box {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 8rpx 8rpx 8rpx 20rpx;
  border: 1rpx solid #eee;
  min-height: 72rpx;
}

.chat-input {
  flex: 1;
  font-size: 28rpx;
  min-height: 40rpx;
  max-height: 200rpx;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  color: #333;
  line-height: 1.5;
}

.chat-input::placeholder {
  color: #bbb;
  line-height: 40rpx;
}

.send-btn {
  width: 72rpx;
  height: 72rpx;
  min-width: 72rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 12rpx;
  transition: all 0.2s;
}

.send-btn.active {
  background: linear-gradient(135deg, #f5c6cb 0%, #f8d7da 100%);
}

.send-icon {
  font-size: 28rpx;
  color: #999;
  transform: rotate(45deg);
}

.send-btn.active .send-icon {
  color: #721c24;
}

/* 分析结果弹窗 */
.analysis-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.analysis-content {
  background: #fff;
  border-radius: 24rpx;
  width: 85%;
  max-height: 70vh;
  overflow: hidden;
}

.modal-header {
  background: #fce7f3;
  padding: 24rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #721c24;
}

.modal-close {
  font-size: 48rpx;
  color: #721c24;
  line-height: 1;
}

.modal-scroll {
  padding: 30rpx;
  max-height: 60vh;
}

.analysis-row {
  margin-bottom: 28rpx;
}

.analysis-row:last-child {
  margin-bottom: 0;
}

.analysis-label {
  font-size: 24rpx;
  color: #856404;
  display: block;
  margin-bottom: 10rpx;
}

.analysis-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.analysis-value.good { color: #28a745; }
.analysis-value.warn { color: #ffc107; }
.analysis-value.bad { color: #fd7e14; }
.analysis-value.severe { color: #dc3545; }

.keyword-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 10rpx;
}

.keyword-tag {
  background: #fff5f5;
  color: #721c24;
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  border: 1rpx solid #f5c6cb;
}

.suggestion-list {
  margin-top: 10rpx;
}

.suggestion-text {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 8rpx;
}
