/* pages/ai/ai.wxss - 与首页统一的配色方案 */
page {
  background: #f5fff9;
}

.ai-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5fff9;
}

.header {
  background: linear-gradient(135deg, #8ddaf8 0%, #B4E8D1 100%);
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-content {
  display: flex;
  align-items: center;
}

.ai-avatar {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.ai-icon {
  font-size: 50rpx;
}

.header-text {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 6rpx;
}

.header-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.restart-btn {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
}

.conversation {
  flex: 1;
  padding: 20rpx;
  height: calc(100vh - 400rpx);
}

.message-list {
  padding-bottom: 20rpx;
}

.message {
  display: flex;
  margin-bottom: 30rpx;
}

.message.user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #F8BBD0 0%, #F48FB1 100%);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  flex-shrink: 0;
}

.message.user .message-avatar {
  background: linear-gradient(135deg, #D1C4E9 0%, #B39DDB 100%);
}

.message-content {
  max-width: 70%;
  margin: 0 16rpx;
}

.message.user .message-content {
  align-items: flex-end;
}

.message-text {
  background: #fff;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: block;
  white-space: pre-wrap;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.message.user .message-text {
  background: linear-gradient(135deg, #D1C4E9 0%, #B39DDB 100%);
  color: #fff;
}

.message-time {
  font-size: 20rpx;
  color: #ccc;
  margin-top: 8rpx;
  display: block;
}

.message.user .message-time {
  text-align: right;
}

.typing {
  background: #fff;
  padding: 24rpx 32rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: #F8BBD0;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

/* 分析结果卡片 */
.result-card {
  background: #fff;
  margin: 0 20rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.result-header {
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.result-content {
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.result-item {
  margin-bottom: 20rpx;
}

.result-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 10rpx;
}

.result-value {
  font-size: 32rpx;
  font-weight: 600;
}

.emotion-good { color: #43e97b; }
.emotion-warn { color: #ffb84d; }
.emotion-bad { color: #ff6b6b; }

.result-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  background: rgba(248, 187, 208, 0.15);
  color: #F06292;
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.suggestion-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.result-actions {
  display: flex;
  gap: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.action-btn.test {
  background: rgba(209, 196, 233, 0.15);
  color: #9575CD;
}

.action-btn.consult {
  background: linear-gradient(135deg, #A5D6A7 0%, #81C784 100%);
  color: #fff;
}

/* 输入区域 */
.input-section {
  background: #fff;
  padding: 20rpx;
  padding-bottom: 40rpx;
  border-top: 1rpx solid #eee;
}

.input-wrapper {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
}

.user-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  max-height: 200rpx;
  min-height: 80rpx;
}

.send-btn {
  background: linear-gradient(135deg, #D1C4E9 0%, #B39DDB 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx 36rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(209, 196, 233, 0.4);
}

.send-btn::after {
  border: none;
}

.send-btn[disabled] {
  opacity: 0.6;
}

.input-tips {
  display: flex;
  justify-content: center;
  margin-top: 16rpx;
  font-size: 20rpx;
  color: #ccc;
}

.separator {
  margin: 0 16rpx;
}
