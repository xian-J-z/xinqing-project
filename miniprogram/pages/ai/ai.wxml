<view class="ai-container">
  <!-- 头部 -->
  <view class="ai-header">
    <view class="ai-header-left">
      <view class="ai-avatar">🤖</view>
      <view class="ai-title-wrap">
        <text class="ai-title">AI心理分析</text>
        <text class="ai-subtitle">豆包大模型 · 专业评估</text>
      </view>
    </view>
    <button class="ai-restart" bindtap="restart">重新开始</button>
  </view>

  <!-- 聊天区域 -->
  <scroll-view class="chat-area" scroll-y scroll-top="{{scrollTop}}" enhanced>
    <view class="chat-list">
      <!-- 消息循环 -->
      <view class="chat-item {{item.role}}" wx:for="{{conversation}}" wx:key="index">
        <view class="avatar ai-avatar-icon" wx:if="{{item.role === 'assistant'}}">🤖</view>
        <view class="bubble-wrap">
          <view class="bubble {{item.role}}">
            <text class="bubble-text">{{item.content}}</text>
          </view>
          <text class="chat-time">{{item.time}}</text>
        </view>
        <view class="avatar user-avatar-icon" wx:if="{{item.role === 'user'}}">我</view>
      </view>

      <!-- 加载中 -->
      <view class="chat-item assistant" wx:if="{{analyzing}}">
        <view class="avatar ai-avatar-icon">🤖</view>
        <view class="bubble-wrap">
          <view class="bubble assistant typing">
            <view class="typing-dot"></view>
            <view class="typing-dot"></view>
            <view class="typing-dot"></view>
          </view>
        </view>
      </view>

      <view id="chat-bottom"></view>
    </view>
  </scroll-view>

  <!-- 输入区域 -->
  <view class="input-area">
    <!-- 结束对话按钮 -->
    <view class="action-btns" wx:if="{{hasAnalysis}}">
      <button class="end-btn" bindtap="showFinalAnalysis">结束对话并查看分析</button>
    </view>
    <view class="input-box">
      <textarea 
        class="chat-input" 
        placeholder="{{hasAnalysis ? '继续描述...' : '请描述你的情绪、压力或困扰...'}}" 
        value="{{userInput}}"
        bindinput="onInput"
        bindlinechange="onLineChange"
        maxlength="500"
        adjust-position
        auto-height
      />
      <view class="send-btn {{canSend ? 'active' : ''}}" bindtap="sendMessage" wx:if="{{canSend || analyzing}}">
        <text class="send-icon">▲</text>
      </view>
    </view>
  </view>

  <!-- 分析结果弹窗 -->
  <view class="analysis-modal" wx:if="{{showAnalysis}}" bindtap="toggleAnalysis">
    <view class="analysis-content" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title">📊 智能分析结果</text>
        <text class="modal-close" bindtap="toggleAnalysis">×</text>
      </view>
      <scroll-view scroll-y class="modal-scroll">
        <view class="analysis-row">
          <text class="analysis-label">情绪状态</text>
          <text class="analysis-value {{getEmotionClass(analysisResult.emotion)}}">{{analysisResult.emotion}}</text>
        </view>
        <view class="analysis-row">
          <text class="analysis-label">风险评分</text>
          <text class="analysis-value">{{analysisResult.score}} / 10</text>
        </view>
        <view class="analysis-row">
          <text class="analysis-label">识别关键词</text>
          <view class="keyword-list">
            <text class="keyword-tag" wx:for="{{analysisResult.keywords}}">{{item}}</text>
          </view>
        </view>
        <view class="analysis-row">
          <text class="analysis-label">专业建议</text>
          <view class="suggestion-list">
            <text class="suggestion-text" wx:for="{{analysisResult.suggestions}}">• {{item}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
