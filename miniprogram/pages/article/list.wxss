/* pages/article/list.wxss - 与首页统一的配色方案 */
page { background: #f5fff9; }

.list-container { padding: 20rpx 30rpx; }

.article-item {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.article-cover {
  width: 100%;
  height: 300rpx;
  overflow: hidden;
}
.article-cover image { width: 100%; height: 100%; }

.article-body { padding: 24rpx 30rpx; }

.article-top {
  display: inline-block;
  font-size: 22rpx;
  color: #ff6b6b;
  background: rgba(255, 107, 107, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}

.article-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.article-meta {
  display: flex;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.meta-author { font-size: 24rpx; color: #5B9BD5; }
.meta-category { font-size: 24rpx; color: #999; background: #f5f5f5; padding: 2rpx 10rpx; border-radius: 6rpx; }
.meta-views { font-size: 24rpx; color: #999; }

.article-time { font-size: 22rpx; color: #ccc; }

.loading-tip, .empty-tip, .end-tip {
  text-align: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: #999;
}
