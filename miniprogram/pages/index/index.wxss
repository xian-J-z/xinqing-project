/* pages/index/index.wxss - 精确配色方案 */
page {
  background: #f5fff9;
}

.index-container {
  min-height: 100vh;
  background:#f5fff9;
  padding-bottom: 30rpx;
}

/* 顶部头部 - 淡蓝渐变 #87CEEB -> #B4E8D1 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 35rpx 30rpx;
  background: linear-gradient(135deg, #8ddaf8 0%, #B4E8D1 100%);
}

.welcome {
  display: flex;
  flex-direction: column;
}

/* 问候语 - 纯白 #FFFFFF */
.welcome-text {
  font-size: 42rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

/* 日期 - 淡白偏绿 #F0F9F6 */
.date-text {
  font-size: 24rpx;
  color: #F0F9F6;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
}

.avatar-emoji {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  background: #FFFFFF;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 40rpx;
  color: #CCCCCC;
}

.role-badge {
  display: inline-block;
  font-size: 22rpx;
  color: #FFFFFF;
  background: rgba(255, 255, 255, 0.25);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-top: 8rpx;
}

/* 置顶轮播 */
.banner-section {
  position: relative;
  margin: 30rpx;
}

.banner {
  height: 320rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.banner-item {
  width: 100%;
  height: 100%;
  position: relative;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-bg {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #87CEEB 0%, #B4E8D1 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 120rpx;
}

.banner-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 30rpx 30rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
}

/* 置顶标签 - 珊瑚红 #FF6B6B */
.banner-top-tag {
  display: inline-block;
  font-size: 20rpx;
  color: #FFFFFF;
  background: #FF6B6B;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  margin-bottom: 10rpx;
}

/* 标题 - 纯白 */
.banner-title {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 作者 - 浅灰白 #F0F0F0 */
.banner-author {
  font-size: 22rpx;
  color:  #F0F0F0 
}

.banner-dots {
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
}

/* 未激活指示器 - 浅灰 #E0E0E0 */
.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #E0E0E0;
  margin: 0 8rpx;
  transition: all 0.3s;
}

/* 激活指示器 - 淡紫色 #819BEA */
.dot.active {
  width: 40rpx;
  border-radius: 8rpx;
  background: #819BEA;
}

/* 快捷入口 - 纯白背景 #FFFFFF */
.quick-entry {
  display: flex;
  justify-content: space-around;
  background: #FFFFFF;
  margin: 0 30rpx;
  padding: 40rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
}

.entry-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 25rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  font-size: 48rpx;
}

/* 精确图标配色 */
.test-icon { background: #FFF3E0; }      /* 心理测评：浅米黄 */
.ai-icon { background: #FFEBEE; }         /* AI分析：浅粉 */
.treehole-icon { background: #E3F2FD; }   /* 心理树洞：浅灰蓝 */
.appoint-icon { background: #E0F7F0; }    /* 预约咨询：浅薄荷绿 */

/* 主文字 - 深灰黑 #333333 */
.entry-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6rpx;
}

/* 辅助文字 - 中灰 #999999 */
.entry-desc {
  font-size: 20rpx;
  color: #999999;
}

/* 文章列表区 */
.articles-section {
  margin-top: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

/* 标题 - 深灰黑 #333333 */
.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  padding-left: 20rpx;
  border-left: 6rpx solid #FFB6C1; /* 淡粉色分割线 */
}

/* 更多 - 中灰 #999999 */
.more-text {
  font-size: 26rpx;
  color: #999999;
}

.article-list {
  padding: 0 30rpx;
}

/* 文章卡片 - 米白色背景 */
.article-card {
  background: #FAF9F6;  /* 米白色 */
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.article-cover-wrap {
  width: 100%;
  height: 300rpx;
  overflow: hidden;
}

.article-cover-img {
  width: 100%;
  height: 100%;
}

.article-info {
  padding: 24rpx 30rpx;
}

/* 文章标题 - 黑色 */
.article-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #000000;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
}

.article-meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.article-author {
  font-size: 22rpx;
  color: #666666;
}

.article-views {
  font-size: 22rpx;
  color: #888888;
}

.article-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.article-category {
  font-size: 20rpx;
  color: #FF6B6B;
  background: rgba(255, 107, 107, 0.1);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.article-date {
  font-size: 22rpx;
  color: #666666;
}

.empty-articles {
  text-align: center;
  padding: 80rpx;
  color: #999999;
  font-size: 28rpx;
}

/* 底部提示 */
.tip-section {
  background: rgba(168, 230, 207, 0.1);
  margin: 30rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  text-align: center;
}

.tip-text {
  font-size: 26rpx;
  color: #666666;
  display: block;
  margin-bottom: 10rpx;
}

.tip-phone {
  font-size: 28rpx;
  color: #5B9BD5;
  font-weight: 600;
}

/* 咨询师工作台 */
.counselor-section {
  margin: 30rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.counselor-header { margin-bottom: 24rpx; }

.counselor-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
}

.counselor-stats {
  display: flex;
  justify-content: space-around;
  background: linear-gradient(135deg, #87CEEB 0%, #B4E8D1 100%);
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.counselor-actions {
  display: flex;
  justify-content: space-around;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 40rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
}

.action-icon { font-size: 48rpx; margin-bottom: 12rpx; }
.action-text { font-size: 24rpx; color: #666666; }
