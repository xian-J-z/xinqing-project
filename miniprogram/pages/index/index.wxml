<!--pages/index/index.wxml-->
<view class="index-container">
  <!-- 置顶文章轮播区 -->
  <view class="banner-section" wx:if="{{topArticles.length > 0}}">
    <swiper class="banner" indicator-dots autoplay circular interval="3000" bindchange="onBannerChange">
      <swiper-item wx:for="{{topArticles}}" wx:key="_id">
        <view class="banner-item" bindtap="goToArticle" data-id="{{item._id}}">
          <image wx:if="{{item.cover}}" class="banner-image" src="{{item.cover}}" mode="aspectFill"/>
          <view wx:else class="banner-bg">{{item.category === '心理健康' ? '💪' : item.category === '情绪管理' ? '😊' : item.category === '人际关系' ? '🤝' : '📚'}}</view>
          <view class="banner-mask">
            <view class="banner-top-tag">📌 置顶</view>
            <text class="banner-title">{{item.title}}</text>
            <text class="banner-author">{{item.authorName || '管理员'}}</text>
          </view>
        </view>
      </swiper-item>
    </swiper>
    <view class="banner-dots" wx:if="{{topArticles.length > 1}}">
      <view class="dot {{currentBanner === index ? 'active' : ''}}" wx:for="{{topArticles}}" wx:key="_id"></view>
    </view>
  </view>

  <!-- 咨询师工作台 -->
  <view class="counselor-section" wx:if="{{userRole === 'counselor'}}">
    <view class="counselor-header">
      <text class="counselor-title">📋 今日工作台</text>
    </view>
    <view class="counselor-stats">
      <view class="stat-item">
        <text class="stat-num">5</text>
        <text class="stat-label">待回复</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">12</text>
        <text class="stat-label">今日咨询</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">98%</text>
        <text class="stat-label">满意度</text>
      </view>
    </view>
    <view class="counselor-actions">
      <view class="action-item" bindtap="goToPublish">
        <text class="action-icon">📝</text>
        <text class="action-text">发表文章</text>
      </view>
      <view class="action-item" bindtap="goToTreehole">
        <text class="action-icon">💬</text>
        <text class="action-text">回复咨询</text>
      </view>
      <view class="action-item" bindtap="goToAppointment">
        <text class="action-icon">📅</text>
        <text class="action-text">预约管理</text>
      </view>
    </view>
  </view>

  <!-- 普通用户快捷入口 -->
  <view class="quick-entry" wx:if="{{userRole !== 'counselor'}}">
    <view class="entry-item" bindtap="goToTest">
      <view class="entry-icon" style="background: linear-gradient(135deg, #EAE5F5 0%, #f0e6fb 100%);;">📋</view>
      <text class="entry-title">心理测评</text>
      <text class="entry-desc">了解你的内心</text>
    </view>
    <view class="entry-item" bindtap="goToAI">
      <view class="entry-icon" style="background: linear-gradient(135deg, #EAE5F5 0%, #f5d6e0 100%);">🤖</view>
      <text class="entry-title">AI分析</text>
      <text class="entry-desc">智能心理分析</text>
    </view>
    <view class="entry-item" bindtap="goToTreehole">
      <view class="entry-icon" style="background: linear-gradient(135deg, #EAE5F5 0%, #cfe6f9 100%);">💬</view>
      <text class="entry-title">心理树洞</text>
      <text class="entry-desc">倾诉你的心声</text>
    </view>
    <view class="entry-item" bindtap="goToAppointment">
      <view class="entry-icon" style="background: linear-gradient(135deg, #EAE5F5 0%, #d6ffd8 100%);">📅</view>
      <text class="entry-title">预约咨询</text>
      <text class="entry-desc">专业心理咨询</text>
    </view>
  </view>

  <!-- 心理文章列表 -->
  <view class="articles-section">
    <view class="section-header">
      <text class="section-title">{{userRole === 'counselor' ? '热门文章' : '心理文章'}}</text>
      <text class="more-text" bindtap="goToArticleList">更多 ></text>
    </view>

    <view class="article-list" wx:if="{{articles.length > 0}}">
      <view class="article-card" wx:for="{{articles}}" wx:key="_id" bindtap="goToArticle" data-id="{{item._id}}">
        <view class="article-cover-wrap" wx:if="{{item.cover}}">
          <image class="article-cover-img" src="{{item.cover}}" mode="aspectFill"/>
        </view>
        <view class="article-info">
          <text class="article-title">{{item.title}}</text>
          <view class="article-meta">
            <text class="article-author">{{item.authorName || '匿名'}}</text>
            <text class="article-views">{{item.viewCount || 0}} 阅读</text>
          </view>
          <view class="article-bottom">
            <text class="article-category">{{item.category}}</text>
            <text class="article-date">{{item.displayTime}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-articles" wx:if="{{!loading && articles.length === 0}}">
      <text>暂无文章</text>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="tip-section">
    <text class="tip-text" wx:if="{{userRole === 'counselor'}}">帮助他人，温暖心灵</text>
    <text class="tip-text" wx:else>如果你感到心理困扰，请及时寻求专业帮助</text>
    <text class="tip-phone">心理援助热线：400-123-4567</text>
  </view>
</view>