/* pages/admin/users.wxss */
page { background: #f5f5f5; }

.users-container { height: 100vh; display: flex; flex-direction: column; }

/* 筛选栏 */
.filter-bar {
  background: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  gap: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-item {
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
}

.filter-item.active {
  background: #667eea;
  color: #fff;
}

/* 用户列表 */
.user-list { flex: 1; padding: 20rpx; }

.user-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.user-item.disabled { opacity: 0.5; }

.user-avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.user-info { flex: 1; }

.user-name { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.user-name text { font-size: 30rpx; font-weight: 500; color: #333; }

.user-role {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}
.role-user { background: #e8f0fe; color: #667eea; }
.role-counselor { background: #fef3c7; color: #f59e0b; }
.role-admin { background: #fee2e2; color: #ef4444; }

.user-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}
.status-active { background: #d1fae5; color: #10b981; }
.status-disabled { background: #fee2e2; color: #ef4444; }

.user-meta { font-size: 22rpx; color: #999; }

.user-actions { display: flex; gap: 16rpx; }

.action-btn {
  font-size: 24rpx;
  color: #667eea;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  background: #e8f0fe;
}
.action-btn.delete { color: #ef4444; background: #fee2e2; }

.empty {
  text-align: center;
  padding: 100rpx;
  color: #999;
  font-size: 28rpx;
}
