/* pages/admin/articles.wxss - 与首页统一的配色方案 */
page { background: #f5fff9; }

.articles-container { height: 100vh; display: flex; flex-direction: column; }

.toolbar {
  background: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.publish-btn {
  background: linear-gradient(135deg, #8ddaf8 0%, #B4E8D1 100%);
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx;
  border-radius: 50rpx;
  border: none;
}

.article-list { flex: 1; padding: 20rpx; }

.article-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
}

.article-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  overflow: hidden;
}
.article-cover image { width: 100%; height: 100%; }

.article-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }

.title-row { display: flex; align-items: center; gap: 8rpx; margin-bottom: 8rpx; }

.top-tag {
  display: inline-block;
  font-size: 20rpx;
  color: #ff6b6b;
  background: rgba(255, 107, 107, 0.1);
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.article-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.article-meta {
  display: flex;
  gap: 16rpx;
  font-size: 22rpx;
  color: #999;
  flex-wrap: wrap;
}

.article-actions { display: flex; flex-direction: column; gap: 12rpx; margin-left: 20rpx; justify-content: center; }

.action-btn {
  font-size: 24rpx;
  color: #5B9BD5;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  background: rgba(141, 218, 248, 0.15);
  text-align: center;
  white-space: nowrap;
}

.top-btn { color: #ffb84d; background: rgba(255, 184, 77, 0.1); }
.top-btn.cancel-top { color: #999; background: #f0f0f0; }
.action-btn.delete { color: #ff6b6b; background: rgba(255, 107, 107, 0.1); }

.empty {
  text-align: center;
  padding: 100rpx;
  color: #999;
  font-size: 28rpx;
}
