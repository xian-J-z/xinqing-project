<!--pages/test/test.wxml-->
<view class="test-container">
  <!-- 测试列表 -->
  <block wx:if="{{!testStarted && !testFinished}}">
    <view class="header">
      <text class="header-title">心理测评</text>
      <text class="header-subtitle">专业的心理健康评估工具</text>
    </view>
    
    <view class="test-list">
      <view 
        class="test-card" 
        wx:for="{{testList}}" 
        wx:key="id"
        bindtap="startTest"
        data-id="{{item.id}}"
      >
        <view class="test-icon" style="background: linear-gradient(135deg, #D1C4E9 0%, #B39DDB 100%);">
          <text>{{item.icon}}</text>
        </view>
        <view class="test-info">
          <text class="test-title">{{item.title}}</text>
          <text class="test-desc">{{item.desc}}</text>
          <view class="test-meta">
            <text class="test-questions">{{item.questions}}题</text>
            <text class="test-time">{{item.time}}</text>
          </view>
        </view>
        <view class="test-arrow">></view>
      </view>
    </view>
    
    <view class="notice-section">
      <text class="notice-title">温馨提示</text>
      <text class="notice-text">1. 请根据您最近一周的实际感受作答</text>
      <text class="notice-text">2. 测评结果仅供参考，不作为诊断依据</text>
      <text class="notice-text">3. 如有严重心理困扰，请及时寻求专业帮助</text>
    </view>
  </block>

  <!-- 测试进行中 -->
  <block wx:if="{{testStarted && !testFinished}}">
    <view class="test-header">
      <view class="test-progress">
        <text class="progress-text">{{currentQuestion + 1}} / {{questions.length}}</text>
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{(currentQuestion + 1) / questions.length * 100}}%"></view>
        </view>
      </view>
      <text class="test-name">{{currentTest.title}}</text>
    </view>
    
    <view class="question-section" wx:if="{{questions[currentQuestion]}}">
      <text class="question-text">第 {{currentQuestion + 1}} 题：{{questions[currentQuestion].content}}</text>
      
      <view class="options">
        <view 
          wx:for="{{questions[currentQuestion].options}}" 
          wx:key="index"
          class="option {{answers[currentQuestion] == item.score ? 'selected' : ''}}" 
          bindtap="selectAnswer" 
          data-score="{{item.score}}"
        >
          <text class="option-score">{{item.score}}</text>
          <text class="option-label">{{item.text}}</text>
        </view>
      </view>
    </view>
    
    <view class="btn-section">
      <button class="btn-prev" bindtap="prevQuestion" wx:if="{{currentQuestion > 0}}">上一题</button>
      <button class="btn-next" bindtap="nextQuestion">
        {{currentQuestion < questions.length - 1 ? '下一题' : '提交测试'}}
      </button>
    </view>
    
    <button class="btn-quit" bindtap="goBack">退出测试</button>
  </block>

  <!-- 测试结果 -->
  <block wx:if="{{testFinished && result}}">
    <view class="result-section">
      <view class="result-header">
        <text class="result-title">测评完成</text>
        <text class="result-test-name">{{result.testTitle}}</text>
      </view>
      
      <view class="result-card">
        <view class="result-level" style="background: {{result.avgScore < 2 ? '#43e97b' : result.avgScore < 3 ? '#ffb84d' : '#ff6b6b'}}">
          {{result.level}}
        </view>
        
        <view class="result-score">
          <text class="score-label">总得分</text>
          <text class="score-value">{{result.totalScore}}</text>
          <text class="score-max">满分{{result.fullScore}}分</text>
        </view>
        
        <view class="result-score">
          <text class="score-label">平均得分</text>
          <text class="score-value">{{result.avgScore}}</text>
          <text class="score-max">满分{{result.maxPerQuestion}}分</text>
        </view>
        
        <view class="result-desc">
          <text class="desc-title">结果说明</text>
          <text class="desc-text">{{result.description}}</text>
        </view>
        
        <view class="result-suggestion">
          <text class="suggestion-title">建议</text>
          <text class="suggestion-text">{{result.suggestion}}</text>
        </view>
        
        <view class="result-date">
          <text>测评时间：{{result.date}}</text>
        </view>
      </view>
      
      <view class="result-actions">
        <button class="btn-back" bindtap="goBack">返回列表</button>
        <button class="btn-ai" bindtap="goToAI">AI深入分析</button>
      </view>
    </view>
  </block>
</view>
