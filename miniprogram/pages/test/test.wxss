/* pages/test/test.wxss - 心理测评页面（紫色风格） */
page {
  background: #F5EFF7;
}

.test-container {
  min-height: 100vh;
  background: #F5EFF7;
}

.header {
  background: linear-gradient(135deg, #E1BEE7 0%, #CE93D8 50%, #BA68C8 100%);
  padding: 50rpx 40rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.test-list {
  padding: 30rpx;
}

.test-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(179, 157, 219, 0.1);
}

.test-card:active {
  transform: scale(0.98);
}

.test-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 25rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  margin-right: 24rpx;
  background: linear-gradient(135deg, #E1BEE7 0%, #CE93D8 100%);
}

.test-info {
  flex: 1;
}

.test-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.test-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

.test-meta {
  display: flex;
}

.test-questions, .test-time {
  font-size: 22rpx;
  color: #9575CD;
  margin-right: 20rpx;
}

.test-arrow {
  font-size: 32rpx;
  color: #CE93D8;
  margin-left: 20rpx;
}

.notice-section {
  background: linear-gradient(135deg, rgba(225, 190, 231, 0.2) 0%, rgba(206, 147, 216, 0.2) 100%);
  margin: 30rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(186, 104, 200, 0.2);
}

.notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #8E24AA;
  display: block;
  margin-bottom: 16rpx;
}

.notice-text {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}

/* 测试进行中 */
.test-header {
  background: #fff;
  padding: 30rpx;
  border-bottom: 1rpx solid #F3E5F5;
}

.test-progress {
  margin-bottom: 20rpx;
}

.progress-text {
  font-size: 26rpx;
  color: #8E24AA;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.progress-bar {
  height: 8rpx;
  background: #F3E5F5;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #CE93D8 0%, #BA68C8 100%);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.test-name {
  font-size: 28rpx;
  color: #666;
}

.question-section {
  padding: 50rpx 30rpx;
}

.question-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 30rpx;
  line-height: 1.6;
}

.scale-hint {
  display: flex;
  justify-content: space-between;
  background: #F5EFF7;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 40rpx;
}

.scale-hint text {
  font-size: 20rpx;
  color: #9575CD;
}

.options {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  padding: 30rpx 10rpx;
  border-radius: 16rpx;
  border: 2rpx solid #F3E5F5;
  transition: all 0.3s;
}

.option.selected {
  background: linear-gradient(135deg, #E1BEE7 0%, #CE93D8 100%);
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(186, 104, 200, 0.2);
}

.option-score {
  font-size: 40rpx;
  font-weight: 700;
  color: #8E24AA;
  margin-bottom: 10rpx;
}

.option.selected .option-score {
  color: #fff;
}

.option-label {
  font-size: 22rpx;
  color: #666;
}

.option.selected .option-label {
  color: rgba(255, 255, 255, 0.9);
}

.btn-section {
  display: flex;
  padding: 30rpx;
  gap: 20rpx;
}

.btn-prev, .btn-next {
  flex: 1;
  padding: 28rpx 0;
  border-radius: 50rpx;
  font-size: 30rpx;
}

.btn-prev {
  background: #fff;
  color: #8E24AA;
  border: 2rpx solid #CE93D8;
}

.btn-next {
  background: linear-gradient(135deg, #CE93D8 0%, #BA68C8 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(186, 104, 200, 0.3);
}

.btn-quit {
  margin: 0 30rpx 30rpx;
  background: transparent;
  color: #B39DDB;
  font-size: 26rpx;
}

/* 测试结果 */
.result-section {
  padding: 30rpx;
}

.result-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.result-test-name {
  font-size: 26rpx;
  color: #666;
}

.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(179, 157, 219, 0.15);
}

.result-level {
  text-align: center;
  padding: 20rpx;
  border-radius: 50rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 40rpx;
  background: linear-gradient(135deg, #CE93D8 0%, #BA68C8 100%);
}

.result-score {
  text-align: center;
  margin-bottom: 40rpx;
}

.score-label {
  font-size: 26rpx;
  color: #9575CD;
  display: block;
  margin-bottom: 10rpx;
}

.score-value {
  font-size: 80rpx;
  font-weight: 700;
  color: #8E24AA;
  display: block;
}

.score-max {
  font-size: 24rpx;
  color: #CE93D8;
}

.result-desc, .result-suggestion {
  margin-bottom: 30rpx;
}

.desc-title, .suggestion-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.desc-text, .suggestion-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.result-date {
  text-align: center;
  font-size: 22rpx;
  color: #CE93D8;
  padding-top: 20rpx;
  border-top: 1rpx solid #F3E5F5;
}

.result-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn-back, .btn-ai {
  flex: 1;
  padding: 28rpx 0;
  border-radius: 50rpx;
  font-size: 30rpx;
}

.btn-back {
  background: #fff;
  color: #8E24AA;
  border: 2rpx solid #CE93D8;
}

.btn-ai {
  background: linear-gradient(135deg, #E1BEE7 0%, #CE93D8 100%);
  color: #fff;
}
