<!--pages/test-storage/test-storage.wxml-->
<view class="container">
  <view class="header">
    <text class="title">本地存储测试</text>
  </view>
  
  <view class="actions">
    <button class="btn" bindtap="addTestData">添加测试数据</button>
    <button class="btn btn-danger" bindtap="clearAllData">清空所有数据</button>
  </view>
  
  <view class="section">
    <text class="section-title">测试记录 ({{storageData.testRecords.length}})</text>
    <view class="data-item" wx:for="{{storageData.testRecords}}" wx:key="id">
      <text class="item-title">{{item.testTitle}}</text>
      <text class="item-info">得分：{{item.avgScore}} | {{item.date}}</text>
    </view>
    <view class="empty" wx:if="{{storageData.testRecords.length === 0}}">暂无测试记录</view>
  </view>
  
  <view class="section">
    <text class="section-title">预约记录 ({{storageData.appointments.length}})</text>
    <view class="data-item" wx:for="{{storageData.appointments}}" wx:key="_id">
      <text class="item-title">{{item.counselorName}}</text>
      <text class="item-info">{{item.date}} {{item.time}} | {{item.status}}</text>
    </view>
    <view class="empty" wx:if="{{storageData.appointments.length === 0}}">暂无预约记录</view>
  </view>
  
  <view class="section">
    <text class="section-title">树洞记录 ({{storageData.treeholeRecords.length}})</text>
    <view class="data-item" wx:for="{{storageData.treeholeRecords}}" wx:key="id">
      <text class="item-title">{{item.content}}</text>
      <text class="item-info">{{item.time}} | ❤️ {{item.likes}} | 💬 {{item.comments}}</text>
    </view>
    <view class="empty" wx:if="{{storageData.treeholeRecords.length === 0}}">暂无树洞记录</view>
  </view>
  
  <view class="section">
    <text class="section-title">AI分析记录 ({{storageData.aiRecords.length}})</text>
    <view class="data-item" wx:for="{{storageData.aiRecords}}" wx:key="index">
      <text class="item-title">AI心理分析</text>
      <text class="item-info">情绪：{{item.emotion}} | {{item.date}}</text>
    </view>
    <view class="empty" wx:if="{{storageData.aiRecords.length === 0}}">暂无AI分析记录</view>
  </view>
</view>
