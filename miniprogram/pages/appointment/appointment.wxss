/* pages/appointment/appointment.wxss - 预约咨询页面（绿色风格） */
page {
  background: #F1F8F2;
}

.appointment-container {
  min-height: 100vh;
  background: #F1F8F2;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #A5D6A7 0%, #81C784 50%, #66BB6A 100%);
  padding: 40rpx 30rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  padding: 30rpx;
  display: block;
}

.counselor-list {
  padding: 0 20rpx;
}

.counselor-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(129, 199, 132, 0.1);
}

.counselor-card:active {
  transform: scale(0.98);
}

.counselor-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 24rpx;
  background: linear-gradient(135deg, #A5D6A7 0%, #81C784 100%);
}

.counselor-avatar-emoji {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 24rpx;
  background: linear-gradient(135deg, #A5D6A7 0%, #81C784 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 60rpx;
}

.selected-counselor .counselor-avatar-emoji {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 20rpx;
  font-size: 40rpx;
}

.counselor-info {
  flex: 1;
}

.counselor-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.counselor-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
}

.status-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.status-tag.available {
  background: rgba(129, 199, 132, 0.2);
  color: #388E3C;
}

.status-tag.unavailable {
  background: rgba(244, 67, 54, 0.1);
  color: #E53935;
}

.counselor-title {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

.counselor-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.tag {
  background: rgba(129, 199, 132, 0.2);
  color: #388E3C;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 10rpx;
  margin-bottom: 8rpx;
}

.counselor-meta {
  display: flex;
}

.meta-item {
  font-size: 22rpx;
  color: #81C784;
  margin-right: 20rpx;
}

.counselor-price {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  text-align: right;
}

.price {
  font-size: 40rpx;
  font-weight: 700;
  color: #E53935;
}

.price-unit {
  font-size: 22rpx;
  color: #A5D6A7;
}

.my-appointments {
  margin-top: 20rpx;
}

.appointment-list {
  padding: 0 20rpx;
}

.appointment-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(129, 199, 132, 0.08);
}

.appointment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.appointment-counselor {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.status-pending {
  background: rgba(255, 183, 77, 0.15);
  color: #F57C00;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-confirmed {
  background: rgba(129, 199, 132, 0.2);
  color: #388E3C;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-completed {
  background: rgba(100, 181, 246, 0.15);
  color: #1976D2;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-rejected {
  background: rgba(244, 67, 54, 0.1);
  color: #E53935;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.view-tabs {
  display: flex;
  background: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #E8F5E9;
}

.view-tabs .tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.view-tabs .tab-item.active {
  color: #388E3C;
  font-weight: 600;
}

.view-tabs .tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(135deg, #A5D6A7 0%, #66BB6A 100%);
  border-radius: 2rpx;
}

.counselor-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 16rpx;
}

.confirm-btn.small {
  width: auto;
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  background: linear-gradient(135deg, #A5D6A7 0%, #81C784 100%);
  color: #fff;
  box-shadow: none;
  border-radius: 30rpx;
}

.reject-btn.small {
  width: auto;
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  background: rgba(244, 67, 54, 0.1);
  color: #E53935;
  box-shadow: none;
  border-radius: 30rpx;
}

.complete-btn.small {
  width: auto;
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  background: linear-gradient(135deg, #81C784 0%, #66BB6A 100%);
  color: #fff;
  box-shadow: none;
  border-radius: 30rpx;
}

.appointment-info {
  margin-bottom: 16rpx;
}

.info-item {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}

.appointment-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.appointment-time {
  font-size: 22rpx;
  color: #A5D6A7;
}

.cancel-btn {
  background: transparent;
  color: #E53935;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border: 1rpx solid #E53935;
  border-radius: 30rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #81C784;
  font-size: 28rpx;
}

/* 预约弹窗 */
.booking-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  max-height: 90vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #E8F5E9;
  position: sticky;
  top: 0;
  background: #fff;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 50rpx;
  color: #A5D6A7;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
}

.selected-counselor {
  display: flex;
  align-items: center;
  background: #F1F8F2;
  padding: 20rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid #C8E6C9;
}

.selected-counselor .counselor-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 20rpx;
}

.selected-counselor .counselor-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.selected-counselor .counselor-title {
  font-size: 22rpx;
  color: #81C784;
}

.form-section {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.date-list {
  display: flex;
  justify-content: flex-start;
  flex-wrap: wrap;
  gap: 16rpx;
}

.date-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  background: #F1F8F2;
  min-width: 100rpx;
  border: 1rpx solid #C8E6C9;
}

.date-item.selected {
  background: linear-gradient(135deg, #A5D6A7 0%, #81C784 100%);
  border-color: transparent;
}

.date-month {
  font-size: 20rpx;
  color: #81C784;
  margin-bottom: 4rpx;
}

.date-item.selected .date-month {
  color: rgba(255, 255, 255, 0.8);
}

.date-weekday {
  font-size: 22rpx;
  color: #A5D6A7;
  margin-bottom: 4rpx;
}

.date-item.selected .date-weekday {
  color: #fff;
}

.date-day {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.date-item.selected .date-day {
  color: #fff;
}

/* 日期约满变红样式 */
.date-item.booked {
  background: #FFEBEE !important;
  border: 2rpx solid #E53935 !important;
}
.date-item.booked .date-month,
.date-item.booked .date-day,
.date-item.booked .date-weekday {
  color: #E53935 !important;
}
.booked-tip {
  font-size: 20rpx;
  color: #E53935;
  margin-top: 4rpx;
}

.time-item-wrapper.booked {
  background: #FFEBEE !important;
  border: 2rpx solid #E53935 !important;
}
.time-item-wrapper.booked .time-text {
  color: #E53935 !important;
}
.time-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.time-item {
  padding: 16rpx 32rpx;
  border-radius: 30rpx;
  background: #F1F8F2;
  font-size: 26rpx;
  color: #333;
  border: 1rpx solid #C8E6C9;
}

.time-item.selected {
  background: linear-gradient(135deg, #A5D6A7 0%, #81C784 100%);
  color: #fff;
  border-color: transparent;
}

/* 时间项容器（带状态标签） */
.time-item-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  background: #F1F8F2;
  min-width: 140rpx;
  border: 1rpx solid #C8E6C9;
}

.time-item-wrapper.selected {
  background: linear-gradient(135deg, #A5D6A7 0%, #81C784 100%);
  border-color: transparent;
}

.time-item-wrapper.booked {
  background: #FFEBEE !important;
  border: 2rpx solid #E53935 !important;
}

.time-text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.time-item-wrapper.selected .time-text {
  color: #fff;
}

.time-item-wrapper.booked .time-text {
  color: #E53935 !important;
}

.time-status {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.status-available {
  background: rgba(129, 199, 132, 0.2);
  color: #388E3C;
}

.time-item-wrapper.selected .status-available {
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
}

.status-booked {
  background: rgba(244, 67, 54, 0.8) !important;
  color: #ffffff !important;
}

.reason-input {
  width: 100%;
  min-height: 150rpx;
  background: #F1F8F2;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 1rpx solid #C8E6C9;
}

.fee-info {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 20rpx 0;
  border-top: 1rpx solid #E8F5E9;
  margin-top: 20rpx;
}

.fee-label {
  font-size: 26rpx;
  color: #666;
}

.fee-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #E53935;
}

.modal-footer {
  padding: 30rpx;
  padding-bottom: 60rpx;
  position: sticky;
  bottom: 0;
  background: #fff;
}

.confirm-btn {
  width: 100%;
  background: linear-gradient(135deg, #A5D6A7 0%, #66BB6A 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  padding: 28rpx 0;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 20rpx rgba(129, 199, 132, 0.3);
}

.confirm-btn::after {
  border: none;
}

/* 咨询师预约管理新增样式 */
.user-info-row {
  display: flex;
  align-items: center;
}

.user-avatar-text {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.user-time {
  font-size: 22rpx;
  color: #81C784;
  margin-top: 4rpx;
}

.status-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.pending-card {
  border-left: 6rpx solid #F57C00;
  background: #FFF8E1;
}

.confirmed-card {
  border-left: 6rpx solid #388E3C;
  background: #F1F8F2;
}

.pending-header {
  margin-bottom: 16rpx;
}

.pending-list {
  padding: 0 20rpx;
}

.confirmed-list {
  padding: 0 20rpx;
  margin-top: 20rpx;
}

.info-row {
  display: flex;
  margin-bottom: 8rpx;
}

.info-label {
  font-size: 26rpx;
  color: #A5D6A7;
  width: 140rpx;
}

.info-value {
  font-size: 26rpx;
  color: #666;
  flex: 1;
}

.pending-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #E8F5E9;
}

.pending-actions .confirm-btn,
.pending-actions .reject-btn,
.pending-actions .complete-btn {
  flex: 1;
  width: auto;
  padding: 20rpx 0;
  font-size: 28rpx;
}

.pending-actions .reject-btn {
  background: rgba(244, 67, 54, 0.1);
  color: #E53935;
  box-shadow: none;
  border-radius: 50rpx;
}

.pending-actions .complete-btn {
  background: linear-gradient(135deg, #81C784 0%, #66BB6A 100%);
  box-shadow: 0 4rpx 12rpx rgba(129, 199, 132, 0.3);
  border-radius: 50rpx;
}
