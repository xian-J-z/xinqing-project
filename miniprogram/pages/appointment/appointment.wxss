/* pages/appointment/appointment.wxss */
.appointment-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
  padding: 40rpx 30rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  padding: 30rpx;
  display: block;
}

.counselor-list {
  padding: 0 20rpx;
}

.counselor-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.counselor-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.counselor-avatar-emoji {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 60rpx;
}

.selected-counselor .counselor-avatar-emoji {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 20rpx;
  font-size: 40rpx;
}

.counselor-info {
  flex: 1;
}

.counselor-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.counselor-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
}

.status-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.status-tag.available {
  background: rgba(67, 233, 123, 0.1);
  color: #43e97b;
}

.status-tag.unavailable {
  background: rgba(255, 107, 107, 0.1);
  color: #ff6b6b;
}

.counselor-title {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

.counselor-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.tag {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 10rpx;
  margin-bottom: 8rpx;
}

.counselor-meta {
  display: flex;
}

.meta-item {
  font-size: 22rpx;
  color: #999;
  margin-right: 20rpx;
}

.counselor-price {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  text-align: right;
}

.price {
  font-size: 40rpx;
  font-weight: 700;
  color: #ff6b6b;
}

.price-unit {
  font-size: 22rpx;
  color: #999;
}

.my-appointments {
  margin-top: 20rpx;
}

.appointment-list {
  padding: 0 20rpx;
}

.appointment-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.appointment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.appointment-counselor {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.status-pending {
  background: rgba(255, 184, 77, 0.1);
  color: #ffb84d;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-confirmed {
  background: rgba(67, 233, 123, 0.1);
  color: #43e97b;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-completed {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-rejected {
  background: rgba(255, 107, 107, 0.1);
  color: #ff6b6b;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.view-tabs {
  display: flex;
  background: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}

.view-tabs .tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.view-tabs .tab-item.active {
  color: #43e97b;
  font-weight: 600;
}

.view-tabs .tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
  border-radius: 2rpx;
}

.counselor-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 16rpx;
}

.confirm-btn.small {
  width: auto;
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
  color: #fff;
  box-shadow: none;
}

.reject-btn.small {
  width: auto;
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  background: rgba(255, 107, 107, 0.1);
  color: #ff6b6b;
  box-shadow: none;
}

.complete-btn.small {
  width: auto;
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: none;
}

.appointment-info {
  margin-bottom: 16rpx;
}

.info-item {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}

.appointment-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.appointment-time {
  font-size: 22rpx;
  color: #ccc;
}

.cancel-btn {
  background: transparent;
  color: #ff6b6b;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border: 1rpx solid #ff6b6b;
  border-radius: 30rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 预约弹窗 */
.booking-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  max-height: 90vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  background: #fff;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 50rpx;
  color: #ccc;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
}

.selected-counselor {
  display: flex;
  align-items: center;
  background: #f9f9f9;
  padding: 20rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.selected-counselor .counselor-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 20rpx;
}

.selected-counselor .counselor-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.selected-counselor .counselor-title {
  font-size: 22rpx;
  color: #999;
}

.form-section {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.date-list {
  display: flex;
  justify-content: space-between;
}

.date-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  min-width: 80rpx;
}

.date-item.selected {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.date-weekday {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.date-item.selected .date-weekday {
  color: #fff;
}

.date-day {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.date-item.selected .date-day {
  color: #fff;
}

.time-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.time-item {
  padding: 16rpx 32rpx;
  border-radius: 30rpx;
  background: #f5f5f5;
  font-size: 26rpx;
  color: #333;
}

.time-item.selected {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
  color: #fff;
}

.reason-input {
  width: 100%;
  min-height: 150rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.fee-info {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 20rpx 0;
  border-top: 1rpx solid #eee;
  margin-top: 20rpx;
}

.fee-label {
  font-size: 26rpx;
  color: #666;
}

.fee-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff6b6b;
}

.modal-footer {
  padding: 30rpx;
  padding-bottom: 60rpx;
  position: sticky;
  bottom: 0;
  background: #fff;
}

.confirm-btn {
  width: 100%;
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  padding: 28rpx 0;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 20rpx rgba(67, 233, 123, 0.4);
}

.confirm-btn::after {
  border: none;
}
