<!-- pages/appointment/appointment.wxml -->
<view class="appointment-container">
  <view class="header">
    <text class="header-title">预约咨询</text>
    <text class="header-desc">专业心理咨询师，为你排忧解难</text>
  </view>

  <!-- 咨询师列表 -->
  <view class="counselor-section">
    <text class="section-title">选择咨询师</text>
    <view class="counselor-list">
      <view 
        class="counselor-card" 
        wx:for="{{counselors}}" 
        wx:key="_id"
        bindtap="selectCounselor"
        data-id="{{item._id}}"
      >
        <view class="counselor-avatar-emoji">{{item.avatar}}</view>
        <view class="counselor-info">
          <view class="counselor-header">
            <text class="counselor-name">{{item.name}}</text>
            <view class="status-tag {{item.available ? 'available' : 'unavailable'}}">
              {{item.available ? '可预约' : '已约满'}}
            </view>
          </view>
          <text class="counselor-title">{{item.title}}</text>
          <view class="counselor-tags">
            <text class="tag" wx:for="{{item.specialties}}" wx:for-item="spec" wx:key="*this">{{spec}}</text>
          </view>
          <view class="counselor-meta">
            <text class="meta-item">🕐 {{item.experience}}</text>
            <text class="meta-item">⭐ {{item.rating}}</text>
            <text class="meta-item">📋 {{item.consults}}次咨询</text>
          </view>
        </view>
        <view class="counselor-price">
          <text class="price">¥{{item.price}}</text>
          <text class="price-unit">/次</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 我的预约 -->
  <view class="my-appointments">
    <text class="section-title">我的预约</text>
    <view class="appointment-list" wx:if="{{appointments.length > 0}}">
      <view class="appointment-card" wx:for="{{appointments}}" wx:key="_id">
        <view class="appointment-header">
          <text class="appointment-counselor">{{item.counselorName}}</text>
          <view wx:if="{{item.status === '待确认'}}" class="status-badge status-pending">{{item.status}}</view>
          <view wx:elif="{{item.status === '已确认'}}" class="status-badge status-confirmed">{{item.status}}</view>
          <view wx:elif="{{item.status === '已完成'}}" class="status-badge status-completed">{{item.status}}</view>
          <view wx:elif="{{item.status === '已拒绝' || item.status === '已取消'}}" class="status-badge status-rejected">{{item.status}}</view>
        </view>
        <view class="appointment-info">
          <text class="info-item">📅 {{item.date}} {{item.time}}</text>
          <text class="info-item">📝 {{item.reason}}</text>
          <text class="info-item">🕐 {{item.createTimeStr}}</text>
        </view>
        <view class="appointment-actions" wx:if="{{item.status === '待确认'}}">
          <button class="cancel-btn" bindtap="cancelAppointment" data-id="{{item._id}}">取消预约</button>
        </view>
      </view>
    </view>
    <view class="empty-state" wx:else>
      <text>暂无预约记录</text>
    </view>
  </view>

  <!-- 预约弹窗 -->
  <view class="booking-modal" wx:if="{{showBookingModal}}">
    <view class="modal-mask" bindtap="closeModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">预约咨询</text>
        <text class="modal-close" bindtap="closeModal">×</text>
      </view>
      
      <view class="modal-body">
        <view class="selected-counselor">
          <view class="counselor-avatar-emoji">{{selectedCounselor.avatar}}</view>
          <view class="counselor-detail">
            <text class="counselor-name">{{selectedCounselor.name}}</text>
            <text class="counselor-title">{{selectedCounselor.title}}</text>
          </view>
        </view>
        
        <view class="form-section">
          <text class="form-label">选择日期（提前一周）</text>
          <view class="date-list">
            <view 
              class="date-item {{selectedDate === item.date ? 'selected' : ''}} {{isDateFullyBooked(item.date) ? 'booked' : ''}}" 
              wx:for="{{dates}}" 
              wx:key="date"
              bindtap="{{isDateFullyBooked(item.date) ? '' : 'selectDate'}}"
              data-date="{{item.date}}"
            >
              <text class="date-month">{{item.month}}月</text>
              <text class="date-day">{{item.day}}</text>
              <text class="date-weekday">{{item.weekDay}}</text>
              <text class="booked-tip" wx:if="{{isDateFullyBooked(item.date)}}">不可约</text>
            </view>
          </view>
        </view>
        
        <view class="form-section">
          <text class="form-label">选择时间</text>
          <view class="time-list">
            <view 
              class="time-item-wrapper {{selectedTime === item ? 'selected' : ''}} {{bookedTimes.includes(item) ? 'booked' : ''}}" 
              wx:for="{{times}}" 
              wx:key="index"
              bindtap="{{bookedTimes.includes(item) ? '' : 'selectTime'}}"
              data-time="{{item}}"
            >
              <text class="time-text">{{item}}</text>
              <text class="time-status {{bookedTimes.includes(item) ? 'status-booked' : 'status-available'}}">
                {{bookedTimes.includes(item) ? '不可约' : '可约'}}
              </text>
            </view>
          </view>
        </view>
        
        <view class="form-section">
          <text class="form-label">预约原因（选填）</text>
          <textarea 
            class="reason-input" 
            placeholder="请简单描述您的问题（选填）" 
            value="{{bookingReason}}"
            bindinput="onReasonInput"
            maxlength="200"
          />
        </view>
        
        <view class="fee-info">
          <text class="fee-label">咨询费用：</text>
          <text class="fee-price">¥{{selectedCounselor.price}}</text>
        </view>
      </view>
      
      <view class="modal-footer">
        <button class="confirm-btn" bindtap="confirmBooking">确认预约</button>
      </view>
    </view>
  </view>
</view>
