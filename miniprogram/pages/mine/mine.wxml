<!--pages/mine/mine.wxml-->
<view class="mine-container">
  <!-- 用户信息头部 -->
  <view class="user-header" bindtap="goToEditProfile">
    <view class="user-bg"></view>
    <view class="user-info">
      <view class="avatar-section">
        <block wx:if="{{userInfo.avatarUrl}}">
          <image 
            class="user-avatar" 
            src="{{userInfo.avatarUrl}}" 
            mode="aspectFill"
          />
        </block>
        <block wx:else>
          <view class="user-avatar-emoji">{{userRole === 'counselor' ? '👨‍⚕️' : '👤'}}</view>
        </block>
      </view>
      <view class="user-detail">
        <text class="user-name">{{userInfo.nickName || '点击登录'}}</text>
        <text class="user-bio" wx:if="{{userInfo.bio}}">{{userInfo.bio}}</text>
        <text class="user-tip" wx:elif="{{userInfo.nickName}}">{{userRole === 'counselor' ? '👨‍⚕️ 心理咨询师' : '🌟 关注心理健康'}}</text>
        <text class="login-hint" wx:else>点击登录/编辑资料</text>
      </view>
      <view class="header-arrow">›</view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="function-list">
    <!-- 心理测评 -->
    <view class="list-item" bindtap="goToTestList">
      <view class="item-left">
        <view class="item-icon" style="background: linear-gradient(135deg, #D1C4E9 0%, #B39DDB 100%);">📋</view>
        <view class="item-info">
          <text class="item-title">心理测评</text>
          <text class="item-desc">了解您的心理健康状态</text>
        </view>
      </view>
      <view class="item-right">
        <text class="item-count">{{stats.testCount}} 条记录</text>
        <text class="item-arrow">›</text>
      </view>
    </view>

    <!-- 预约咨询 -->
    <view class="list-item" bindtap="goToAppointment">
      <view class="item-left">
        <view class="item-icon" style="background: linear-gradient(135deg, #A5D6A7 0%, #81C784 100%);">📅</view>
        <view class="item-info">
          <text class="item-title">预约咨询</text>
          <text class="item-desc">专业心理咨询师为您服务</text>
        </view>
      </view>
      <view class="item-right">
        <text class="item-count">{{stats.appointmentCount}} 条记录</text>
        <text class="item-arrow">›</text>
      </view>
    </view>

    <!-- 心理树洞 -->
    <view class="list-item" bindtap="goToTreeholeList">
      <view class="item-left">
        <view class="item-icon" style="background: linear-gradient(135deg, #90CAF9 0%, #64B5F6 100%);">💬</view>
        <view class="item-info">
          <text class="item-title">心理树洞</text>
          <text class="item-desc">倾诉心声，释放压力</text>
        </view>
      </view>
      <view class="item-right">
        <text class="item-count">{{stats.treeholeCount}} 条记录</text>
        <text class="item-arrow">›</text>
      </view>
    </view>

    <!-- AI心理分析 -->
    <view class="list-item" bindtap="goToAIList">
      <view class="item-left">
        <view class="item-icon" style="background: linear-gradient(135deg, #F8BBD0 0%, #F48FB1 100%);">🤖</view>
        <view class="item-info">
          <text class="item-title">AI心理分析</text>
          <text class="item-desc">智能分析您的心理状态</text>
        </view>
      </view>
      <view class="item-right">
        <text class="item-count">{{stats.aiCount}} 条记录</text>
        <text class="item-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{userInfo.nickName}}">
    <view class="logout-btn" bindtap="logout">
      <text class="logout-icon">🚪</text>
      <text class="logout-text">退出登录</text>
    </view>
  </view>
</view>
