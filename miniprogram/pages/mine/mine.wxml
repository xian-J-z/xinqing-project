<!--pages/mine/mine.wxml-->
<view class="mine-container">
  <!-- 用户信息头部 -->
  <view class="user-header">
    <view class="user-bg"></view>
    <view class="user-info">
      <block wx:if="{{userInfo.avatarUrl}}">
        <image 
          class="user-avatar" 
          src="{{userInfo.avatarUrl}}" 
          mode="aspectFill"
        />
      </block>
      <block wx:else>
        <view class="user-avatar-emoji">{{userRole === 'counselor' ? '👨‍⚕️' : '👤'}}</view>
      </block>
      <view class="user-detail">
        <text class="user-name">{{userInfo.nickName || '未登录用户'}}</text>
        <text class="user-tip" wx:if="{{userInfo.nickName}}">
          <block wx:if="{{userRole === 'counselor'}}">👨‍⚕️ 心理咨询师</block>
          <block wx:else>关注心理健康，享受美好生活</block>
        </text>
        <button class="login-tip-btn" wx:else bindtap="goToLogin">点击登录</button>
      </view>
    </view>
  </view>

  <!-- 普通用户统计卡片 -->
  <view class="stats-card" wx:if="{{userRole !== 'counselor'}}">
    <view class="stat-item" bindtap="switchTab" data-index="0">
      <text class="stat-value">{{stats.testCount}}</text>
      <text class="stat-label">测评记录</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="switchTab" data-index="1">
      <text class="stat-value">{{stats.appointmentCount}}</text>
      <text class="stat-label">预约记录</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="switchTab" data-index="2">
      <text class="stat-value">{{stats.treeholeCount}}</text>
      <text class="stat-label">树洞记录</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="switchTab" data-index="3">
      <text class="stat-value">{{stats.aiCount}}</text>
      <text class="stat-label">AI分析</text>
    </view>
  </view>

  <!-- 咨询师统计卡片 -->
  <view class="counselor-stats-card" wx:if="{{userRole === 'counselor'}}">
    <view class="counselor-header">
      <text class="counselor-title">📊 工作统计</text>
    </view>
    <view class="counselor-stats-grid">
      <view class="counselor-stat-item">
        <text class="counselor-stat-value">{{counselorStats.todayReplies}}</text>
        <text class="counselor-stat-label">今日回复</text>
      </view>
      <view class="counselor-stat-item">
        <text class="counselor-stat-value">{{counselorStats.totalReplies}}</text>
        <text class="counselor-stat-label">总回复数</text>
      </view>
      <view class="counselor-stat-item">
        <text class="counselor-stat-value">{{counselorStats.totalConsults}}</text>
        <text class="counselor-stat-label">咨询总数</text>
      </view>
      <view class="counselor-stat-item">
        <text class="counselor-stat-value">{{counselorStats.avgRating}}</text>
        <text class="counselor-stat-label">满意度</text>
      </view>
    </view>
  </view>

  <!-- 快捷功能 -->
  <view class="quick-actions">
    <!-- 普通用户功能 -->
    <block wx:if="{{userRole !== 'counselor'}}">
      <view class="action-card" bindtap="goToTest">
        <view class="action-icon" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
          <text>📝</text>
        </view>
        <text class="action-text">心理测评</text>
      </view>
      <view class="action-card" bindtap="goToAppointment">
        <view class="action-icon" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);">
          <text>📅</text>
        </view>
        <text class="action-text">预约咨询</text>
      </view>
      <view class="action-card" bindtap="goToTreehole">
        <view class="action-icon" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
          <text>🌳</text>
        </view>
        <text class="action-text">心理树洞</text>
      </view>
      <view class="action-card" bindtap="goToAI">
        <view class="action-icon" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
          <text>🤖</text>
        </view>
        <text class="action-text">AI分析</text>
      </view>
    </block>
    <!-- 咨询师功能 -->
    <block wx:else>
      <view class="action-card" bindtap="goToTreehole">
        <view class="action-icon" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
          <text>💬</text>
        </view>
        <text class="action-text">回复咨询</text>
      </view>
      <view class="action-card" bindtap="goToAppointment">
        <view class="action-icon" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);">
          <text>📅</text>
        </view>
        <text class="action-text">预约管理</text>
      </view>
      <view class="action-card" bindtap="goToTest">
        <view class="action-icon" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
          <text>📊</text>
        </view>
        <text class="action-text">查看报告</text>
      </view>
      <view class="action-card" bindtap="goToAI">
        <view class="action-icon" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
          <text>📝</text>
        </view>
        <text class="action-text">咨询记录</text>
      </view>
    </block>
  </view>

  <!-- Tab切换 -->
  <view class="record-tabs">
    <!-- 普通用户 -->
    <block wx:if="{{userRole !== 'counselor'}}">
      <view 
        class="tab {{currentTab === 0 ? 'active' : ''}}" 
        bindtap="switchTab" 
        data-index="0"
      >
        <text>测评</text>
      </view>
      <view 
        class="tab {{currentTab === 1 ? 'active' : ''}}" 
        bindtap="switchTab" 
        data-index="1"
      >
        <text>预约</text>
      </view>
      <view 
        class="tab {{currentTab === 2 ? 'active' : ''}}" 
        bindtap="switchTab" 
        data-index="2"
      >
        <text>树洞</text>
      </view>
      <view 
        class="tab {{currentTab === 3 ? 'active' : ''}}" 
        bindtap="switchTab" 
        data-index="3"
      >
        <text>AI分析</text>
      </view>
    </block>
    <!-- 咨询师 -->
    <block wx:else>
      <view 
        class="tab {{currentTab === 0 ? 'active' : ''}}" 
        bindtap="switchTab" 
        data-index="0"
      >
        <text>今日</text>
      </view>
      <view 
        class="tab {{currentTab === 1 ? 'active' : ''}}" 
        bindtap="switchTab" 
        data-index="1"
      >
        <text>预约</text>
      </view>
      <view 
        class="tab {{currentTab === 2 ? 'active' : ''}}" 
        bindtap="switchTab" 
        data-index="2"
      >
        <text>回复</text>
      </view>
      <view 
        class="tab {{currentTab === 3 ? 'active' : ''}}" 
        bindtap="switchTab" 
        data-index="3"
      >
        <text>统计</text>
      </view>
    </block>
  </view>

  <!-- 记录列表 -->
  <scroll-view scroll-y class="record-list">
    <!-- 测评/今日记录 -->
    <view class="record-section" wx:if="{{currentTab === 0}}">
      <block wx:if="{{userRole !== 'counselor'}}">
        <view class="record-card" wx:for="{{testRecords}}" wx:key="id" bindtap="goToTestDetail" data-id="{{item.id}}">
          <view class="record-header">
            <text class="record-title">{{item.testTitle}}</text>
            <view wx:if="{{item.level === '心理健康' || item.level === '良好'}}" class="record-badge badge-good">{{item.level}}</view>
            <view wx:elif="{{item.level === '轻度心理问题' || item.level === '轻度困扰' || item.level === '待确认'}}" class="record-badge badge-warn">{{item.level}}</view>
            <view wx:elif="{{item.level === '中度心理问题' || item.level === '需要关注'}}" class="record-badge badge-bad">{{item.level}}</view>
            <view wx:else class="record-badge badge-warn">{{item.level}}</view>
          </view>
          <view class="record-info">
            <text class="info-item">得分：{{item.avgScore}}</text>
            <text class="info-item">日期：{{item.date}}</text>
          </view>
        </view>
        <view class="empty-tip" wx:if="{{testRecords.length === 0}}">
          <text>暂无测评记录</text>
        </view>
      </block>
      <block wx:else>
        <!-- 咨询师今日工作 -->
        <view class="today-work-card">
          <view class="work-header">
            <text class="work-title">📋 今日工作概览</text>
          </view>
          <view class="work-item">
            <text class="work-label">待回复帖子</text>
            <text class="work-value">3</text>
          </view>
          <view class="work-item">
            <text class="work-label">已回复咨询</text>
            <text class="work-value">5</text>
          </view>
          <view class="work-item">
            <text class="work-label">今日预约</text>
            <text class="work-value">2</text>
          </view>
        </view>
      </block>
    </view>

    <!-- 预约记录 -->
    <view class="record-section" wx:if="{{currentTab === 1}}">
      <view class="record-card" wx:for="{{appointmentRecords}}" wx:key="id">
        <view class="record-header">
          <text class="record-title">{{item.counselorName || '预约咨询'}}</text>
          <view wx:if="{{item.status === '已确认'}}" class="record-badge badge-good">{{item.status}}</view>
          <view wx:elif="{{item.status === '待确认'}}" class="record-badge badge-warn">{{item.status}}</view>
          <view wx:else class="record-badge badge-warn">{{item.status}}</view>
        </view>
        <view class="record-info">
          <text class="info-item">📅 {{item.date}} {{item.time}}</text>
          <text class="info-item">📝 {{item.reason}}</text>
        </view>
      </view>
      <view class="empty-tip" wx:if="{{appointmentRecords.length === 0}}">
        <text>暂无预约记录</text>
      </view>
    </view>

    <!-- 树洞/回复记录 -->
    <view class="record-section" wx:if="{{currentTab === 2}}">
      <view class="record-card" wx:for="{{treeholeRecords}}" wx:key="id">
        <text class="record-content">{{item.content}}</text>
        <view class="record-footer">
          <text class="record-time">{{item.time}}</text>
          <view class="record-actions">
            <text>❤️ {{item.likes}}</text>
            <text>💬 {{item.comments}}</text>
          </view>
        </view>
      </view>
      <view class="empty-tip" wx:if="{{treeholeRecords.length === 0}}">
        <text wx:if="{{userRole === 'counselor'}}">暂无回复记录</text>
        <text wx:else>暂无树洞记录</text>
      </view>
    </view>

    <!-- AI分析/统计 -->
    <view class="record-section" wx:if="{{currentTab === 3}}">
      <block wx:if="{{userRole !== 'counselor'}}">
        <view class="record-card ai-card" wx:for="{{aiRecords}}" wx:key="index">
          <view class="record-header">
            <text class="record-title">AI心理分析</text>
            <view wx:if="{{item.emotion === '良好'}}" class="record-badge badge-good">{{item.emotion}}</view>
            <view wx:elif="{{item.emotion === '轻度困扰'}}" class="record-badge badge-warn">{{item.emotion}}</view>
            <view wx:elif="{{item.emotion === '需要关注'}}" class="record-badge badge-bad">{{item.emotion}}</view>
            <view wx:else class="record-badge badge-warn">{{item.emotion}}</view>
          </view>
          <view class="record-info">
            <text class="info-item">关键词：{{item.keywords.join('、')}}</text>
            <text class="info-item">日期：{{item.date}}</text>
          </view>
          <view class="suggestion-preview">
            <text class="preview-label">建议：</text>
            <text class="preview-text">{{item.suggestions[0]}}</text>
          </view>
        </view>
        <view class="empty-tip" wx:if="{{aiRecords.length === 0}}">
          <text>暂无AI分析记录</text>
        </view>
      </block>
      <block wx:else>
        <!-- 咨询师统计 -->
        <view class="stat-detail-card">
          <text class="stat-detail-title">📈 工作详情</text>
          <view class="stat-detail-item">
            <text>本周回复</text>
            <text class="stat-detail-value">35</text>
          </view>
          <view class="stat-detail-item">
            <text>本月回复</text>
            <text class="stat-detail-value">128</text>
          </view>
          <view class="stat-detail-item">
            <text>平均评分</text>
            <text class="stat-detail-value">4.9</text>
          </view>
        </view>
      </block>
    </view>
  </scroll-view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{userInfo}}">
    <button class="logout-btn" bindtap="logout">退出登录</button>
  </view>
</view>
