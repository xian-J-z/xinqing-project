/* pages/mine/mine.wxss */
.mine-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.user-header {
  position: relative;
}

.user-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 0 0 60rpx 60rpx;
}

.user-info {
  position: relative;
  display: flex;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
  z-index: 1;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 30rpx;
  background: rgba(255, 255, 255, 0.2);
}

.user-avatar-emoji {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 70rpx;
}

.user-detail {
  flex: 1;
}

.user-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 10rpx;
}

.user-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-tip-btn {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 26rpx;
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
}

.stats-card {
  display: flex;
  background: #fff;
  margin: 30rpx;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #667eea;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
  margin-top: 10rpx;
}

.quick-actions {
  display: flex;
  padding: 0 30rpx;
  gap: 20rpx;
}

.action-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.action-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 22rpx;
  color: #333;
}

.record-tabs {
  display: flex;
  background: #fff;
  margin: 30rpx;
  border-radius: 16rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-weight: 600;
}

.record-list {
  padding: 0 30rpx;
  height: 500rpx;
}

.record-section {
  padding-bottom: 20rpx;
}

.record-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.record-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.record-badge {
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.badge-good {
  background: rgba(67, 233, 123, 0.1);
  color: #43e97b;
}

.badge-warn {
  background: rgba(255, 184, 77, 0.1);
  color: #ffb84d;
}

.badge-bad {
  background: rgba(255, 107, 107, 0.1);
  color: #ff6b6b;
}

.record-info {
  margin-bottom: 12rpx;
}

.info-item {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 6rpx;
}

.record-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-time {
  font-size: 22rpx;
  color: #ccc;
}

.record-actions {
  display: flex;
  gap: 20rpx;
}

.record-actions text {
  font-size: 22rpx;
  color: #999;
}

.ai-card .suggestion-preview {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.preview-label {
  font-size: 24rpx;
  color: #999;
}

.preview-text {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-top: 8rpx;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #ccc;
  font-size: 28rpx;
}

.logout-section {
  padding: 30rpx;
  margin-top: 20rpx;
}

.logout-btn {
  width: 100%;
  background: transparent;
  color: #ff6b6b;
  font-size: 30rpx;
  padding: 24rpx 0;
  border: 2rpx solid #ff6b6b;
  border-radius: 50rpx;
}

/* 咨询师样式 */
.counselor-stats-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  margin: 30rpx;
  border-radius: 20rpx;
  padding: 30rpx;
}

.counselor-header {
  margin-bottom: 20rpx;
}

.counselor-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.counselor-stats-grid {
  display: flex;
  justify-content: space-around;
}

.counselor-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.counselor-stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.counselor-stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 今日工作卡片 */
.today-work-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.work-header {
  margin-bottom: 20rpx;
}

.work-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.work-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.work-item:last-child {
  border-bottom: none;
}

.work-label {
  font-size: 28rpx;
  color: #666;
}

.work-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #667eea;
}

/* 统计详情卡片 */
.stat-detail-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.stat-detail-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.stat-detail-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 28rpx;
  color: #666;
}

.stat-detail-item:last-child {
  border-bottom: none;
}

.stat-detail-value {
  font-weight: 600;
  color: #667eea;
}
