/* pages/mine/mine.wxss - 与首页统一的配色方案 */
page {
  background: #f5fff9;
}

.mine-container {
  min-height: 100vh;
  background: #f5fff9;
  padding-bottom: 40rpx;
}

/* 用户信息头部 - 蓝色渐变 */
.user-header {
  position: relative;
  background: linear-gradient(135deg, #8ddaf8 0%, #B4E8D1 100%);
  padding: 60rpx 30rpx 50rpx;
}

.user-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 240rpx;
  border-radius: 0 0 60rpx 60rpx;
}

.user-info {
  position: relative;
  display: flex;
  align-items: center;
  z-index: 1;
}

.avatar-section {
  position: relative;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  background: rgba(255, 255, 255, 0.2);
}

.user-avatar-emoji {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 60rpx;
}

.user-detail {
  flex: 1;
  margin-left: 30rpx;
}

/* 用户名 - 纯白 */
.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
  margin-bottom: 8rpx;
}

/* 签名/角色 */
.user-tip {
  font-size: 24rpx;
  color: #F0F8F5;
  display: block;
}

.user-bio {
  font-size: 24rpx;
  color: #F0F8F5;
  display: block;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.login-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  display: block;
}

.header-arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 300;
}

/* 功能列表 */
.function-list {
  margin: 30rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.list-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
}

.item-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 24rpx;
  font-size: 40rpx;
}

/* 图标配色 */
.test-icon { background: #FFF3E0; }
.appoint-icon { background: #E0F7F0; }
.treehole-icon { background: #E3F2FD; }
.ai-icon { background: #FFEBEE; }

.item-info {
  display: flex;
  flex-direction: column;
}

/* 主文字 */
.item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 6rpx;
}

/* 辅助文字 */
.item-desc {
  font-size: 22rpx;
  color: #999999;
  display: block;
}

.item-right {
  display: flex;
  align-items: center;
}

.item-count {
  font-size: 24rpx;
  color: #999999;
  margin-right: 16rpx;
}

.item-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  font-weight: 300;
}

/* 退出登录 */
.logout-section {
  margin: 40rpx 30rpx 0;
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  background: #FFFFFF;
  color: #FF6B6B;
  font-size: 30rpx;
  padding: 28rpx 0;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.logout-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.logout-text {
  font-weight: 500;
}
