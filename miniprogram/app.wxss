/* 文字颜色由 app.json 的 navigationBarTextStyle 控制 */

/* ========== TabBar 相关 ========== */
/* TabBar 配置在 app.json 中 */

/* ========== 功能图标容器 ========== */
.entry-icon,
.feature-icon,
.item-icon,
.ai-avatar,
.test-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}
