/**app.wxss - 全局样式与配色方案**/
/* ========== 页面基础样式 ========== */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

page {
  background: #f5fff9;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* ========== 全局配色变量 ========== */
:root {
  /* 主色调 */
  --color-primary: #8ddaf8;
  --color-primary-light: #B4E8D1;
  --color-primary-gradient: linear-gradient(135deg, #8ddaf8 0%, #B4E8D1 100%);
  
  /* 页面背景 */
  --color-bg: #f5fff9;
  --color-bg-white: #ffffff;
  
  /* 文字颜色 */
  --color-text-primary: #333333;
  --color-text-secondary: #999999;
  
  /* 功能图标配色 */
  --color-test: linear-gradient(135deg, #D1C4E9 0%, #B39DDB 100%);     /* 心理测评-紫色 */
  --color-ai: linear-gradient(135deg, #F8BBD0 0%, #F48FB1 100%);      /* AI分析-粉色 */
  --color-treehole: linear-gradient(135deg, #90CAF9 0%, #64B5F6 100%); /* 心理树洞-蓝色 */
  --color-appointment: linear-gradient(135deg, #A5D6A7 0%, #81C784 100%); /* 预约咨询-绿色 */
  
  /* 辅助色 */
  --color-success: #43e97b;
  --color-warning: #ffb84d;
  --color-danger: #ff6b6b;
  --color-info: #64B5F6;
}

/* ========== 通用按钮样式 ========== */
.btn-primary {
  background: var(--color-primary-gradient);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  box-shadow: 0 8rpx 20rpx rgba(141, 218, 248, 0.4);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-secondary {
  background: #fff;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
}

/* ========== 卡片样式 ========== */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

/* ========== 标题样式 ========== */
.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  padding: 20rpx 30rpx;
  border-left: 6rpx solid var(--color-primary);
  margin: 20rpx 0;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 50rpx;
  color: #999;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

/* ========== 加载状态 ========== */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 50rpx;
  color: #999;
}

/* ========== 通用输入框 ========== */
.input-field {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  margin: 20rpx 0;
}

/* ========== 标签样式 ========== */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
}

.tag-primary {
  background: rgba(141, 218, 248, 0.15);
  color: var(--color-primary);
}

.tag-success {
  background: rgba(67, 233, 123, 0.15);
  color: var(--color-success);
}

.tag-warning {
  background: rgba(255, 184, 77, 0.15);
  color: var(--color-warning);
}

.tag-danger {
  background: rgba(255, 107, 107, 0.15);
  color: var(--color-danger);
}

.tag-test {
  background: rgba(209, 196, 233, 0.15);
  color: #9575CD;
}

.tag-ai {
  background: rgba(248, 187, 208, 0.15);
  color: #F06292;
}

.tag-treehole {
  background: rgba(100, 181, 246, 0.15);
  color: #42A5F5;
}

.tag-appointment {
  background: rgba(129, 199, 132, 0.15);
  color: #66BB6A;
}

/* ========== 导航栏相关 ========== */
